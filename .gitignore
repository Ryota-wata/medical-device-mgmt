!/taniguchi/work/
!/taniguchi/work/README.md
.claude/worktrees/

# docs (all local only)
/docs/


# Excel temp files
~$*

# build output (accidental commit)
/out */

# screenshots (regenerable)
/screenshots/

# playwright MCP logs (regenerable)
/.playwright-mcp/

# design (all local only)
/design/

# external skills
/.claude/skills/awesome-skills/


