# Figma API 設定
# このファイルを .env.figma にコピーして値を入力してください
# cp .env.figma.example .env.figma

# Personal Access Token
# 取得方法: Figma → 左上アイコン → Settings → Personal Access Tokens → Generate
FIGMA_TOKEN=figd_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Figma ファイルキー
# FigmaファイルURLから取得:
#   https://www.figma.com/design/XXXXXXXXX/ファイル名?...
#                                ^^^^^^^^^ ← この部分
FIGMA_FILE_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
