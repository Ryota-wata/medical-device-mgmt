  entity "models" as models {
    * 型式ID / model_id : bigint
    --
    メーカーID / manufacturer_id : bigint
    型式名 / model_name : varchar
    有効フラグ / is_active : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
