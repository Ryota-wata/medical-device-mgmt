@startuml
hide circle
hide methods
top to bottom direction
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam packageStyle rectangle

' 認証・ユーザー系
package "認証・ユーザー" {
  entity "feature_catalogs" as feature_catalogs {
    * 機能コード / feature_code : varchar
    --
    機能名 / feature_name : varchar
    大分類コード / category_code : varchar
    メニューグループコード / menu_group_code : varchar
    機能種別 / feature_kind : varchar
    利用文脈 / usage_context : varchar
    設定スコープ / config_scope : varchar
    表示順 / sort_order : int
    有効フラグ / is_active : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "column_catalogs" as column_catalogs {
    * カラムコード / column_code : varchar
    --
    カラム名 / column_name : varchar
    関連機能コード / related_feature_code : varchar
    カラム分類コード / column_group_code : varchar
    利用文脈 / usage_context : varchar
    表示順 / sort_order : int
    有効フラグ / is_active : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "users" as users {
    * ユーザーID / user_id : bigint
    --
    メールアドレス（ログインID） / email_address : varchar
    パスワードハッシュ / password_hash : varchar
    氏名 / name : varchar
    設立母体ID / establishment_id : bigint
    施設ID / facility_id : bigint
    アカウント種別 / account_type : varchar
    所属部門 / department_name : varchar
    所属部署 / section_name : varchar
    役職 / position_name : varchar
    連絡担当者名 / contact_person_name : varchar
    電話番号 / phone_number : varchar
    アカウント有効フラグ / is_active : boolean
    アカウントロック日時 / locked_at : timestamp
    ロック理由 / lock_reason : varchar
    最終ログイン日時 / last_login_at : timestamp
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }

  entity "user_facility_assignments" as user_facility_assignments {
    * ユーザー施設割当ID / user_facility_assignment_id : bigint
    --
    ユーザーID / user_id : bigint
    施設ID / facility_id : bigint
    割当種別 / assignment_type : varchar
    既定選択フラグ / is_default : boolean
    有効フラグ / is_active : boolean
    適用開始日 / valid_from : date
    適用終了日 / valid_to : date
    作成者ユーザーID / created_by : bigint
    更新者ユーザーID / updated_by : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  note right of user_facility_assignments
    直接割り当てられた
    作業対象施設のみを保持する。
    他施設閲覧グループ経由で見える施設は
    本テーブルへ展開しない。
  end note

  entity "facility_feature_settings" as facility_feature_settings {
    * 施設機能設定ID / facility_feature_setting_id : bigint
    --
    施設ID / facility_id : bigint
    機能コード / feature_code : varchar
    有効フラグ / is_enabled : boolean
    作成者ユーザーID / created_by : bigint
    更新者ユーザーID / updated_by : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "facility_column_settings" as facility_column_settings {
    * 施設カラム設定ID / facility_column_setting_id : bigint
    --
    施設ID / facility_id : bigint
    カラムコード / column_code : varchar
    有効フラグ / is_enabled : boolean
    作成者ユーザーID / created_by : bigint
    更新者ユーザーID / updated_by : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "user_facility_feature_settings" as user_facility_feature_settings {
    * ユーザー施設機能設定ID / user_facility_feature_setting_id : bigint
    --
    ユーザー施設割当ID / user_facility_assignment_id : bigint
    機能コード / feature_code : varchar
    有効フラグ / is_enabled : boolean
    作成者ユーザーID / created_by : bigint
    更新者ユーザーID / updated_by : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "user_facility_column_settings" as user_facility_column_settings {
    * ユーザー施設カラム設定ID / user_facility_column_setting_id : bigint
    --
    ユーザー施設割当ID / user_facility_assignment_id : bigint
    カラムコード / column_code : varchar
    有効フラグ / is_enabled : boolean
    作成者ユーザーID / created_by : bigint
    更新者ユーザーID / updated_by : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "user_remember_tokens" as user_remember_tokens {
    * トークンID / token_id : bigint
    --
    ユーザーID / user_id : bigint
    記憶トークン / token : varchar
    有効期限 / expires_at : timestamp
    最終ログイン状態復元日時 / last_used_at : timestamp
    作成日時 / created_at : timestamp
  }

  entity "password_reset_tokens" as password_reset_tokens {
    * トークンID / token_id : bigint
    --
    ユーザーID / user_id : bigint
    リセットトークン / token : varchar
    有効期限 / expires_at : timestamp
    使用日時 / used_at : timestamp
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }
}

' 施設・ロケーション系
package "施設・ロケーション" {
  entity "establishments" as establishments {
    * 設立母体ID / establishment_id : bigint
    --
    設立母体名 / establishment_name : varchar
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }

  entity "facilities" as facilities {
    * 施設ID / facility_id : bigint
    --
    設立母体ID / establishment_id : bigint
    施設コード / facility_code : varchar
    施設名 / facility_name : varchar
    都道府県 / prefecture : varchar
    病床数 / bed_count : int(7)
    システム利用契約状態 / system_contract_status : varchar
    システム利用契約終了日 / system_contract_ended_on : date
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }

  entity "facility_collaboration_groups" as facility_collaboration_groups {
    * 施設協業グループID / facility_collaboration_group_id : bigint
    --
    グループ名 / group_name : varchar
    有効フラグ / is_active : boolean
    作成者ユーザーID / created_by : bigint
    更新者ユーザーID / updated_by : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "facility_collaboration_group_facilities" as facility_collaboration_group_facilities {
    * 施設協業グループ所属施設ID / facility_collaboration_group_facility_id : bigint
    --
    施設協業グループID / facility_collaboration_group_id : bigint
    施設ID / facility_id : bigint
    作成者ユーザーID / created_by : bigint
    更新者ユーザーID / updated_by : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "facility_external_view_settings" as facility_external_view_settings {
    * 他施設公開データ設定ID / facility_external_view_setting_id : bigint
    --
    公開元施設ID / provider_facility_id : bigint
    機能コード / feature_code : varchar
    有効フラグ / is_enabled : boolean
    作成者ユーザーID / created_by : bigint
    更新者ユーザーID / updated_by : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "facility_external_column_settings" as facility_external_column_settings {
    * 他施設公開カラム設定ID / facility_external_column_setting_id : bigint
    --
    公開元施設ID / provider_facility_id : bigint
    カラムコード / column_code : varchar
    有効フラグ / is_enabled : boolean
    作成者ユーザーID / created_by : bigint
    更新者ユーザーID / updated_by : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  note right of facility_collaboration_groups
    任意の施設グループで
    他施設閲覧候補を定義する。
    実際に何を見せるかは
    facility_external_view_settings /
    facility_external_column_settings
    で制御する。
  end note

  entity "facility_locations" as facility_locations {
    * 施設ロケーションID / facility_location_id : bigint
    --
    施設ID / facility_id : bigint
    施設側部門ID / division_id : varchar
    施設側部署ID / department_id : varchar
    施設側諸室ID / room_id : varchar
    棟 / building : varchar
    階 / floor : varchar
    部門名 / department_name : varchar
    部署名 / section_name : varchar
    室名称 / room_name : varchar
    SHIP部署ID / ship_department_id : bigint
    SHIP諸室区分ID / ship_room_category_id : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }

  note right of facility_locations
    現有品調査・調査登録内容修正の
    部門/部署候補の正本。
    棟/階は施設により NULL 可。
    室名は候補表示に使うが、
    画面では自由記述も許容する。
  end note

  entity "ship_departments" as ship_departments {
    * SHIP部署ID / ship_department_id : bigint
    --
    部門名 / division_name : varchar
    部署名 / department_name : varchar
    並び順 / sort_order : int
    有効フラグ / is_active : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  note right of ship_departments
    個別部署マスタとの関係は 1:1 ではない。
    1つの SHIP部署に複数の facility_locations が
    紐づくことを許容する。
    共通マスタとして並び替え・絞り込み・
    標準候補に利用する。
  end note

  entity "ship_room_categories" as ship_room_categories {
    * SHIP諸室区分ID / ship_room_category_id : bigint
    --
    諸室区分1 / room_category1 : varchar
    諸室区分2 / room_category2 : varchar
    並び順 / sort_order : int
    有効フラグ / is_active : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "facility_location_remodels" as facility_location_remodels {
    * 施設ロケーションリモデルID / facility_location_remodel_id : bigint
    --
    施設ロケーションID / facility_location_id : bigint
    新SHIP部署ID / target_ship_department_id : bigint
    新SHIP諸室区分ID / target_ship_room_category_id : bigint
    新棟 / target_building : varchar
    新階 / target_floor : varchar
    新部門名 / target_department_name : varchar
    新部署名 / target_section_name : varchar
    新室名称 / target_room_name : varchar
    新室数 / target_room_count : int
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }
}

' 資産マスタ・分類系
package "資産マスタ・分類" {
  entity "asset_categories" as asset_categories {
    * カテゴリID / category_id : bigint
    --
    カテゴリ名 / category_name : varchar
    並び順 / sort_order : int
    有効フラグ / is_active : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "asset_large_classes" as asset_large_classes {
    * 大分類ID / large_class_id : bigint
    --
    カテゴリID / category_id : bigint
    大分類名 / large_class_name : varchar
    並び順 / sort_order : int
    有効フラグ / is_active : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "asset_medium_classes" as asset_medium_classes {
    * 中分類ID / medium_class_id : bigint
    --
    大分類ID / large_class_id : bigint
    中分類名 / medium_class_name : varchar
    並び順 / sort_order : int
    有効フラグ / is_active : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "asset_items" as asset_items {
    * 品目ID / asset_item_id : bigint
    --
    中分類ID / medium_class_id : bigint
    品目名 / item_name : varchar
    有効フラグ / is_active : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "manufacturers" as manufacturers {
    * メーカーID / manufacturer_id : bigint
    --
    品目ID / asset_item_id : bigint
    メーカー名 / manufacturer_name : varchar
    有効フラグ / is_active : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
