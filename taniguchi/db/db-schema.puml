' 調査・登録・履歴
package "調査・登録・履歴" {
  entity "asset_survey_sessions" as asset_survey_sessions {
    * 調査セッションID / asset_survey_session_id : bigint
    --
    施設ID / facility_id : bigint
    作成者ユーザーID / created_by_user_id : bigint
    開始日時 / started_at : timestamp
    終了日時 / ended_at : timestamp
    ステータス / status : varchar
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "asset_survey_records" as asset_survey_records {
    * 調査レコードID / asset_survey_record_id : bigint
    --
    調査セッションID / asset_survey_session_id : bigint
    施設ID / facility_id : bigint
    施設ロケーションID / facility_location_id : bigint
    カテゴリID / category_id : bigint
    大分類ID / large_class_id : bigint
    中分類ID / medium_class_id : bigint
    品目ID / asset_item_id : bigint
    メーカーID / manufacturer_id : bigint
    型式ID / model_id : bigint
    調査日 / survey_date : date
    調査担当者ユーザーID / surveyor_user_id : bigint
    確定者ユーザーID / confirmed_by_user_id : bigint
    確定日時 / confirmed_at : timestamp
    棟 / building : varchar
    階 / floor : varchar
    部門名 / department_name : varchar
    部署名 / section_name : varchar
    室名称 / room_name : varchar
    QR識別子 / qr_identifier : varchar
    明細区分 / detail_type : varchar
    親調査レコードID / parent_asset_survey_record_id : bigint
    Category名 / category_name : varchar
    大分類名 / large_class_name : varchar
    中分類名 / medium_class_name : varchar
    品目名 / asset_item_name : varchar
    メーカー名 / manufacturer_name : varchar
    型式名 / model_name : varchar
    資産番号 / asset_no : varchar
    ME番号 / equipment_no : varchar
    シリアル番号 / serial_no : varchar
    購入日 / purchased_on : date
    幅(mm) / width_mm : varchar
    奥行(mm) / depth_mm : varchar
    高さ(mm) / height_mm : varchar
    備考 / remarks : varchar
    調査ステータス / survey_status : varchar
    現場登録日時 / registered_at : timestamp
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }

  note right of asset_survey_records
    表示値スナップショットと
    対応マスタIDを併存させる。
    Category/大分類/中分類/品目/メーカー/型式
    の各階層で、マスタ選択済みの値と
    自由記述値が混在する
    ケースを扱うため。
    自由記述時は対応IDを NULL とする。
    部門/部署は facility_locations
    由来の値を正本とし、
    室名は候補選択 + 自由記述を許容。
    既存ロケーションに解決できない場合
    facility_location_id は NULL 可。
    surveyor_user_id は調査実行者。
    confirmed_by_user_id / confirmed_at は
    修正画面での確定者監査。
  end note

  entity "asset_survey_photos <<VIEW>>" as asset_survey_photos {
    * 調査写真ID / asset_survey_photo_id : bigint
    --
    調査レコードID / asset_survey_record_id : bigint
    ファイル名 / file_name : varchar
    ファイルパス / file_path : varchar
    撮影日時 / taken_at : timestamp
    撮影者ユーザーID / taken_by_user_id : bigint
    代表写真フラグ / is_primary : boolean
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  note right of asset_survey_photos
    VIEW over application_documents where
    owner_type='ASSET_SURVEY_RECORD'
    and document_category='PHOTO'
    and deleted_at IS NULL
    asset_survey_photo_id = application_document_id
    asset_survey_record_id =
    application_documents.asset_survey_record_id
    survey photo file_path example:
    asset-survey/{facility_id}/{YYYY}/{MM}/{local_photo_uuid}.{ext}
    file_name is system-generated for display/download
  end note
}

