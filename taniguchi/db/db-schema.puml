' インポート・マッチング・統合
package "インポート・マッチング" {
  entity "asset_import_jobs" as asset_import_jobs {
    * 資産インポートジョブID / asset_import_job_id : bigint
    --
    施設ID / facility_id : bigint
    取込種別 / import_type : varchar
    ファイル名 / file_name : varchar
    ファイルパス / file_path : varchar
    ステータス / status : varchar
    エラーメッセージ / error_message : varchar
    開始日時 / started_at : timestamp
    終了日時 / finished_at : timestamp
    実行ユーザーID / created_by_user_id : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  note right of asset_import_jobs
    status:
    PROCESSING = 初期取込処理中
    READY_FOR_MATCHING = 突き合わせ待ち
    MATCHING_COMPLETED = 突き合わせ完了
    FAILED = 初期取込失敗
    file_path = 再取込用元ファイルの保持先
    error_message = FAILED時の利用者向け失敗理由
    未完了ジョブは施設ごとに1件まで
    同一施設内では別ユーザーが引継ぎ可能
  end note

  entity "asset_import_rows" as asset_import_rows {
    * 資産インポート行ID / asset_import_row_id : bigint
    --
    資産インポートジョブID / asset_import_job_id : bigint
    行番号 / row_no : int
    元データJSON / raw_data_json : json
    固定資産番号（取込） / parsed_ledger_no : varchar
    管理機器番号（取込） / parsed_management_device_no : varchar
    資産名（取込） / parsed_asset_name : varchar
    メーカー名（取込） / parsed_manufacturer_name : varchar
    型式名（取込） / parsed_model_name : varchar
    部門名（取込） / parsed_department_name : varchar
    部署名（取込） / parsed_section_name : varchar
    諸室名称（取込） / parsed_room_name : varchar
    Category（取込） / parsed_category_name : varchar
    数量（取込） / parsed_quantity : int
    単位（取込） / parsed_unit : varchar
    検収日（取込） / parsed_inspection_date : date
    選択Category名 / selected_category_name : varchar
    選択大分類名 / selected_large_class_name : varchar
    選択中分類名 / selected_medium_class_name : varchar
    選択品目名 / selected_asset_item_name : varchar
    選択メーカー名 / selected_manufacturer_name : varchar
    選択型式名 / selected_model_name : varchar
    選択CategoryID / selected_category_id : bigint
    選択大分類ID / selected_large_class_id : bigint
    選択中分類ID / selected_medium_class_id : bigint
    選択品目ID / selected_asset_item_id : bigint
    選択メーカーID / selected_manufacturer_id : bigint
    選択型式ID / selected_model_id : bigint
    候補Category名 / suggested_category_name : varchar
    候補大分類名 / suggested_large_class_name : varchar
    候補中分類名 / suggested_medium_class_name : varchar
    候補品目名 / suggested_asset_item_name : varchar
    候補メーカー名 / suggested_manufacturer_name : varchar
    候補型式名 / suggested_model_name : varchar
    候補CategoryID / suggested_category_id : bigint
    候補大分類ID / suggested_large_class_id : bigint
    候補中分類ID / suggested_medium_class_id : bigint
    候補品目ID / suggested_asset_item_id : bigint
    候補メーカーID / suggested_manufacturer_id : bigint
    候補型式ID / suggested_model_id : bigint
    類似度スコア / suggested_score : decimal(5,3)
    確定済みフラグ / is_confirmed : boolean
    確定者ユーザーID / confirmed_by_user_id : bigint
    確定日時 / confirmed_at : timestamp
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }

  note right of asset_import_rows
    `selected_*_name` / `suggested_*_name`
    は画面表示用の正本文字列。
    マスタ選択時は対応する
    `*_id` も保持し、
    自由記述時は `*_id` を NULL とする。
    これはCategory/大分類/中分類/品目/メーカー/型式
    の各階層で、マスタ候補採用と
    自由記述が混在する
    ケースを扱うため。
    is_confirmed=true の場合は
    confirmed_by_user_id / confirmed_at を保持し、
    未確定行のみ編集対象とする。
    一覧の直接表示対象は
    parsed_department_name / parsed_section_name /
    parsed_asset_name / parsed_manufacturer_name /
    parsed_model_name / parsed_quantity / parsed_unit。
  end note

