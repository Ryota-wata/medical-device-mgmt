  entity "jmdn_classifications" as jmdn_classifications {
    * JMDN分類ID / jmdn_classification_id : bigint
    --
    類別コード / class_code : varchar
    類別名称 / class_name : varchar
    中分類名 / middle_class_name : varchar
    一般的名称 / general_name : varchar
    JMDNコード / jmdn_code : varchar
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "jmdn_registered_items" as jmdn_registered_items {
    * JMDN登録品目ID / jmdn_registered_item_id : bigint
    --
    JMDN分類ID / jmdn_classification_id : bigint
    販売名 / product_name : varchar
    製造販売業者等 / manufacturer_name : varchar
    添付文書URL / attachment_url : varchar
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "model_jmdn_mappings" as model_jmdn_mappings {
    * 型式ID / model_id : bigint
    * JMDN登録品目ID / jmdn_registered_item_id : bigint
    --
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }
}

' 資産台帳・ドキュメント・写真
package "資産台帳" {
  entity "asset_ledgers" as asset_ledgers {
    * 資産台帳ID / asset_ledger_id : bigint
    --
    施設ID / facility_id : bigint
    施設ロケーションID / facility_location_id : bigint
    カテゴリID / category_id : bigint
    品目ID / asset_item_id : bigint
    メーカーID / manufacturer_id : bigint
    型式ID / model_id : bigint
    大分類 / large_class_name : varchar
    中分類 / medium_class_name : varchar
    品目 / asset_item_name : varchar
    メーカー / manufacturer_name : varchar
    型式 / model_name : varchar
    資産名 / asset_name : varchar
    SHIP部門名 / ship_division_name : varchar
    SHIP部署名 / ship_department_name : varchar
    諸室区分1 / room_category1 : varchar
    諸室区分2 / room_category2 : varchar
    室名称 / room_name : varchar
    設置場所 / installation_location : varchar
    資産番号 / asset_no : varchar
    管理機器番号 / management_no : varchar
    ME番号 / equipment_no : varchar
    シリアル番号 / serial_no : varchar
    明細区分 / detail_type : varchar
    親資産台帳ID / parent_asset_ledger_id : bigint
    購入日 / purchased_on : date
    リース品フラグ / is_leased : boolean
    貸出品フラグ / is_rented_out : boolean
    数量 / quantity : int
    単位 / unit : varchar
    幅(mm) / width_mm : varchar
    奥行(mm) / depth_mm : varchar
    高さ(mm) / height_mm : varchar
    契約・見積名称 / contract_name : varchar
    契約番号 / contract_no : varchar
    見積番号 / quotation_no : varchar
    契約・発注日 / contract_date : date
    納品日 / delivery_date : date
    検収日 / inspection_date : date
    取得価格 / acquisition_cost : decimal(14,2)
    電源区分 / power_type : varchar
    消費電力(VA) / power_capacity_va : int
    ネットワーク接続フラグ / system_connected : boolean
    IPアドレス / ip_address : varchar
    MACアドレス / mac_address : varchar
    設置日 / installed_on : date
    保守契約満了日 / maintenance_contract_until : date
    リース開始日 / lease_start_on : date
    リース満了日 / lease_end_on : date
    耐用年数（法定） / legal_service_life : varchar
    使用年数（メーカー推奨） / recommended_service_life : varchar
    販売終了日 / end_of_service_on : date
    メンテ終了日 / end_of_support_on : date
    登録元発注明細ID / source_order_item_id : bigint
    ステータス / status : varchar
    最終棚卸日 / last_inventory_date : date
    最終棚卸ユーザーID / last_inventory_user_id : bigint
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "asset_documents <<VIEW>>" as asset_documents {
    * 資産ドキュメントID / asset_document_id : bigint
    --
    所有者種別 / owner_type : varchar
    申請ID / application_id : bigint
    申請明細ID / application_asset_id : bigint
    見積依頼ID / rfq_id : bigint
    見積依頼先ID / rfq_vendor_id : bigint
    見積ID / quotation_id : bigint
    点検結果ID / inspection_result_id : bigint
    資産台帳ID / asset_ledger_id : bigint
    ドキュメント区分 / document_category : varchar
    ドキュメント種別 / document_type : varchar
    タイトル / title : varchar
    ファイル名 / file_name : varchar
    ファイルパス / file_path : varchar
    文書日付 / document_date : date
    登録者ユーザーID / uploaded_by_user_id : bigint
    登録日時 / uploaded_at : timestamp
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }

  entity "asset_photos <<VIEW>>" as asset_photos {
    * 資産写真ID / asset_photo_id : bigint
    --
    資産台帳ID / asset_ledger_id : bigint
    調査記録ID / survey_record_id : bigint
    ファイルパス / file_path : varchar
    撮影日時 / taken_at : timestamp
    撮影者ユーザーID / taken_by_user_id : bigint
    代表写真フラグ / is_primary : boolean
    表示順 / sort_order : int
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }
}

' QRコード
package "QRコード" {
  entity "qr_codes" as qr_codes {
    * QRコードID / qr_code_id : bigint
    --
    資産台帳ID / asset_ledger_id : bigint
    施設ID / facility_id : bigint
    QR識別子 / qr_identifier : varchar
    コードプレフィックス / code_prefix : char(1)
    コード枝番（2桁） / code_branch : char(2)
    コード連番（5桁） / code_serial : int
    発行種別 / issue_type : varchar
    テンプレートキー / label_template_key : varchar
    フリー記入項目 / free_entry_text : varchar
    最終発行者ユーザーID / issued_by_user_id : bigint
    最終発行日時 / issued_at : timestamp
    印刷状態 / print_status : varchar
    最終印刷ジョブID / last_print_job_id : bigint
    最終印刷日時 / printed_at : timestamp
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }

  note right of qr_codes
    UNIQUE(facility_id, qr_identifier)
    UNIQUE(facility_id, code_prefix, code_branch, code_serial)
    code_serial is assigned as max + 1 per
    (facility_id, code_prefix, code_branch)
    in a server-side transaction
    label_template_key refers to
    frontend-fixed Tepra Creator templates
    latest print operator is resolved via
    last_print_job_id -> qr_print_jobs.requested_by_user_id
  end note

  entity "qr_print_jobs" as qr_print_jobs {
    * 印刷ジョブID / qr_print_job_id : bigint
    --
    施設ID / facility_id : bigint
    テンプレートキー / template_key : varchar
    プリンタ名 / printer_name : varchar
    実行者ユーザーID / requested_by_user_id : bigint
    依頼日時 / requested_at : timestamp
    開始日時 / started_at : timestamp
    終了日時 / finished_at : timestamp
    ステータス / status : varchar
    成功件数 / success_count : int
    失敗件数 / failure_count : int
    エラー概要 / error_summary : varchar
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }

  entity "qr_print_job_items" as qr_print_job_items {
    * 印刷ジョブ明細ID / qr_print_job_item_id : bigint
    --
    印刷ジョブID / qr_print_job_id : bigint
    QRコードID / qr_code_id : bigint
    印刷順 / print_order : int
    ステータス / status : varchar
    印刷日時 / printed_at : timestamp
    エラーメッセージ / error_message : varchar
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
  }
}

' 編集リスト
package "編集リスト" {
  entity "edit_lists" as edit_lists {
    * 編集リストID / edit_list_id : bigint
    --
    編集リスト名 / list_name : varchar
    作成者ユーザーID / created_by_user_id : bigint
    主施設ID / primary_facility_id : bigint
    リスト種別 / list_type : varchar
    ステータス / status : varchar
    最終アクセス日時 / last_accessed_at : timestamp
    作成日時 / created_at : timestamp
    更新日時 / updated_at : timestamp
    削除日時 / deleted_at : timestamp
  }

  entity "edit_list_facilities" as edit_list_facilities {
